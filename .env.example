# Anubhavah — Environment Variables
# Copy this to .env.local and fill in your values

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/anubhavah?retryWrites=true&w=majority

# JWT signing secret (generate: openssl rand -hex 64)
JWT_SECRET=your-very-long-random-secret-here

# Owner bootstrap code — this becomes your admin login code
OWNER_CODE=OWNER_SECRET_CODE_HERE

# Cloudinary credentials (from cloudinary.com dashboard)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# App URL (used for CORS / absolute URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
